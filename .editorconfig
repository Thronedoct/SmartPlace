root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4

[*.ps1]
end_of_line = crlf

[*.{md,csv,txt,json,html,css,js,py}]
end_of_line = lf

[*.{png,jpg,jpeg,jar,pdf,zip,rar}]
trim_trailing_whitespace = false
insert_final_newline = false
